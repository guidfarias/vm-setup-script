# =============================================================================
# /etc/restic/env — Configuração do backup (restic + tar.gz para S3)
# RunCloud / CIPNET
#
# COMO USAR:
#   1. Copie este arquivo para o servidor:   /etc/restic/env
#   2. Preencha os valores reais (troque tudo que estiver como "SUA_...").
#   3. Proteja o arquivo (contém senhas!):
#        chmod 600 /etc/restic/env
#        chown root:root /etc/restic/env
#      (O script RECUSA rodar se as permissões não forem 600 ou 400.)
#
# ⚠️  REGRA DE ASPAS — LEIA:
#   - SENHAS: use ASPAS SIMPLES ' '. O script faz `source` deste arquivo com
#     `set -u`, então um cifrão ($) dentro de aspas duplas seria interpretado
#     como variável e QUEBRARIA o backup (ou mudaria a senha silenciosamente).
#       CERTO:   RESTIC_PASSWORD='ab$cd*ef'
#       ERRADO:  RESTIC_PASSWORD="ab$cd*ef"   <-- $cd vira variável!
#   - Valores com $(...) que você QUER expandir (ex.: hostname): aspas DUPLAS.
#       Ex.:     S3_PREFIX="$(hostname -s)"
#
# ⚠️  RECUPERAÇÃO DE DESASTRE:
#   A RESTIC_PASSWORD é a ÚNICA forma de ler os backups restic. Se você perder
#   este servidor, sem essa senha guardada EM OUTRO LUGAR (gerenciador de
#   senhas, cofre) TODOS os backups restic ficam irrecuperáveis. O mesmo vale
#   para as chaves AWS. Guarde-as fora do servidor.
# =============================================================================


# -----------------------------------------------------------------------------
# CREDENCIAIS AWS / S3
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID='SUA_ACCESS_KEY'
AWS_SECRET_ACCESS_KEY='SUA_SECRET_KEY'
AWS_DEFAULT_REGION='sa-east-1'

# Bucket S3 onde tudo é armazenado.
S3_BUCKET='runcloud-cipnet'

# Prefixo por servidor. Aspas DUPLAS aqui é proposital (queremos o hostname).
S3_PREFIX="$(hostname -s)"

# Onde o repositório restic (deduplicado, diário) fica dentro do bucket.
# Resultado: s3://<S3_BUCKET>/Restic/<hostname>/
RESTIC_S3_PREFIX="Restic/$(hostname -s)"

# Senha do repositório restic. ASPAS SIMPLES. NUNCA perca isto (ver aviso acima).
RESTIC_PASSWORD='SUA_SENHA_RESTIC_FORTE'


# -----------------------------------------------------------------------------
# ORIGEM DO BACKUP
# -----------------------------------------------------------------------------
# Diretório raiz que o restic vai versionar. Padrão do RunCloud: /home.
# (Deixe /home a menos que você tenha um layout diferente.)
BACKUP_SOURCE='/home'

# Onde os dumps .sql.gz do MySQL são gravados antes de irem para o backup.
DB_DUMP_DIR='/home/backups/db'


# -----------------------------------------------------------------------------
# MYSQL
# -----------------------------------------------------------------------------
# As credenciais são passadas ao mysql/mysqldump via arquivo temporário
# (--defaults-extra-file), então NÃO aparecem no `ps aux`.
MYSQL_USER='root'
MYSQL_PASSWORD='SENHA_ROOT_DO_BANCO_AQUI'   # ASPAS SIMPLES (senha pode ter $ * etc.)
MYSQL_HOST='localhost'


# -----------------------------------------------------------------------------
# RETENÇÃO DO RESTIC (backup diário deduplicado)
# -----------------------------------------------------------------------------
# Quantos snapshots manter. O restic aplica isto com `forget --prune`.
# Ex.: 7 diários + 2 semanais + 2 mensais = boa cobertura sem inflar custo.
KEEP_DAILY='7'
KEEP_WEEKLY='2'
KEEP_MONTHLY='2'


# -----------------------------------------------------------------------------
# ARQUIVOS SEMANAIS .tar.gz (cópia baixável direto do S3, independente do restic)
# -----------------------------------------------------------------------------
# Gera um .tar.gz por aplicação em s3://<bucket>/Snapshots/<host>/<data>/.
# Serve como "plano B": se o repositório restic corromper, você ainda tem
# arquivos que baixa e descompacta sem precisar do restic.
ENABLE_WEEKLY_ARCHIVES='true'

# Dia da semana em que os .tar.gz são gerados (0=Dom, 1=Seg ... 5=Sex, 6=Sáb).
ARCHIVE_DAY='5'

# Prefixo (pasta) no bucket para esses arquivos baixáveis.
ARCHIVE_S3_PREFIX='Snapshots'

# RETENÇÃO dos .tar.gz: quantas PASTAS de data manter. As mais antigas que
# excederem esse número são apagadas do S3 automaticamente (prune_weekly_archives).
# Sem isso, os .tar.gz acumulariam para sempre e o custo do S3 só cresceria.
ARCHIVE_KEEP_WEEKS='4'


# -----------------------------------------------------------------------------
# CHECK DE INTEGRIDADE (restic check)
# -----------------------------------------------------------------------------
# Dia da semana do check (0=Dom). Verifica se os dados no repo estão íntegros.
CHECK_DAY='0'

# Quanto de dado ler no check. Pode ser tamanho fixo (ex.: 5G) ou percentual
# (ex.: 10%). Percentual é melhor: escala junto com o crescimento do repo.
CHECK_DATA_SUBSET='10%'


# -----------------------------------------------------------------------------
# OPERAÇÃO / SEGURANÇA
# -----------------------------------------------------------------------------
# Espaço livre mínimo (MB) exigido em DB_DUMP_DIR antes de dumpar os bancos.
# Evita encher o disco no meio do dump. Padrão: 2048 (2 GB).
MIN_FREE_MB='2048'

# Arquivo de log. Rotacionado automaticamente ao passar de LOG_MAX_LINES.
LOG_FILE='/var/log/restic-backup.log'

# (Opcional) máximo de linhas do log antes de truncar. Padrão do script: 5000.
# LOG_MAX_LINES='5000'

# (Opcional) arquivo de lock que impede duas execuções simultâneas (flock).
# LOCK_FILE='/var/run/restic-backup.lock'


# -----------------------------------------------------------------------------
# ALERTAS (opcional) — deixe vazio/comentado para usar só o log
# -----------------------------------------------------------------------------
# URL de um check do Healthchecks.io (ou compatível). Se preenchido, o script
# sinaliza início, sucesso e falha automaticamente — e você é avisado até se o
# script NÃO rodar. Deixe comentado se for monitorar por outro meio (ex.: MCP).
# HEALTHCHECK_URL='https://hc-ping.com/SEU-UUID-AQUI'
